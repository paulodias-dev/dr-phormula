# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Porta usada pelo servidor Express/Vite.
PORT="3000"

# E-mail que receberá as receitas enviadas pelo formulário.
PRESCRIPTION_RECIPIENT_EMAIL="orcamentos@seudominio.com.br"

# Limite máximo do arquivo da receita em MB.
PRESCRIPTION_MAX_FILE_SIZE_MB="10"

# Limite do payload JSON. Deve ser maior que o arquivo, pois base64 aumenta o tamanho do envio.
PRESCRIPTION_JSON_LIMIT="25mb"

# Configurações SMTP para envio dos e-mails.
SMTP_HOST="smtp.seudominio.com.br"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="usuario@seudominio.com.br"
SMTP_PASS="SMTP_PASSWORD_HERE"
SMTP_FROM="Dr.Phormula <usuario@seudominio.com.br>"
SMTP_REPLY_TO="usuario@seudominio.com.br"
